<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="miao.byusi.pc.xylt.ProfileController"
      fx:id="rootBox"
      stylesheets="@../styles/profile.css"
      spacing="20" padding="20">

    <Label text="个人中心" styleClass="page-title"/>

    <!-- 用户信息卡片 -->
    <HBox spacing="20" styleClass="profile-header">
        <VBox spacing="10">
            <Label fx:id="nicknameLabel" styleClass="nickname-label" text="用户昵称">
                <font>
                    <Font size="24"/>
                </font>
            </Label>
            <Label fx:id="usernameLabel" styleClass="username-label" text="@username"/>
            <Label fx:id="bioLabel" styleClass="bio-label" text="暂无个人简介"/>
        </VBox>

        <Region HBox.hgrow="ALWAYS"/>

        <VBox spacing="5" alignment="CENTER">
            <Label fx:id="articleCountLabel" styleClass="count-label" text="0"/>
            <Label text="文章"/>
        </VBox>

        <VBox spacing="5" alignment="CENTER">
            <Label fx:id="followCountLabel" styleClass="count-label" text="0"/>
            <Label text="关注"/>
        </VBox>

        <VBox spacing="5" alignment="CENTER">
            <Label fx:id="followerCountLabel" styleClass="count-label" text="0"/>
            <Label text="粉丝"/>
        </VBox>

        <Button text="编辑资料" styleClass="edit-button" onAction="#showEditProfileDialog"/>
    </HBox>

    <!-- 内容标签页 -->
    <TabPane fx:id="contentTabPane" VBox.vgrow="ALWAYS" styleClass="content-tabpane">
        <Tab text="我的文章" closable="false">
            <ScrollPane fitToWidth="true">
                <VBox fx:id="articlesList" spacing="12" padding="10"/>
            </ScrollPane>
        </Tab>

        <Tab text="我的收藏" closable="false">
            <ScrollPane fitToWidth="true">
                <VBox fx:id="favoritesList" spacing="12" padding="10"/>
            </ScrollPane>
        </Tab>

        <Tab text="我的关注" closable="false">
            <ScrollPane fitToWidth="true">
                <VBox fx:id="followingList" spacing="12" padding="10"/>
            </ScrollPane>
        </Tab>

        <Tab text="通知" closable="false">
            <ScrollPane fitToWidth="true">
                <VBox fx:id="notificationsList" spacing="12" padding="10"/>
            </ScrollPane>
        </Tab>
    </TabPane>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="刷新" styleClass="refresh-button" onAction="#refreshData"/>
    </HBox>

</VBox>
